def get_classification(filename, image):
    plt.figure(figsize=(6, 6))
    plt.imshow(image)
    plt.axis("off")
    plt.show(block=False)  # Non-blocking show
    plt.pause(0.1)  # Pause to allow the plot to update

    # Create a hidden root window for the dialog
    root = Tk()
    root.withdraw()  # Hide the root window

    while True:
        label = simpledialog.askstring(
            "Classification",
            f"Classify {filename}:\n"
            "(o/1 = open, c/3 = closed, n/2 = nearly closed, u/0 = unclear)"
        )
        if label is None:  # User pressed "x" or closed the dialog
            plt.close()  # Close the image window
            print("User closed the input dialog. Exiting program.")
            return None
        if label:
            # Map numeric inputs to their corresponding keys
            label_mapping = {
                "1": "o",  # 1 is equivalent to 'o'
                "2": "n",  # 2 is equivalent to 'n'
                "3": "c",  # 3 is equivalent to 'c'
                "0": "u",  # 0 is equivalent to 'u'
            }
            # Convert the input to lowercase and check if it's a numeric key
            label = label.lower()
            label = label_mapping.get(label, label)  # Use the mapped value if it exists, otherwise use the original input

            # Get the classification based on the mapped or original input
            classification = {"o": "open", "n": "nearly closed", "c": "closed", "u": "unclear"}.get(label)
            if classification:
                plt.close()  # Close image window on valid input
                root.destroy()  # Close the hidden root window
                return classification

def open_image(image_path):
    image = Image.open(image_path)
    plt.imshow(image)
    plt.axis("off")
    plt.show()

def crop_middle(image, division=10):
    width, height = image.size
    crop_size = int((height ** 2) / division) ** 0.5

    left = (width - crop_size) // 2
    top = (height - crop_size) // 2
    right = left + crop_size
    bottom = top + crop_size

    return image.crop((left, top, right, bottom)), (left, top, right, bottom)

def draw_overlay(image, crop_box):
    overlay = image.copy()
    draw = ImageDraw.Draw(overlay)
    draw.rectangle(crop_box, outline="red", width=3)
    return overlay

def annotate_image(image, text):
    draw = ImageDraw.Draw(image)
    font = ImageFont.truetype("arial.ttf", 30)  # Larger font size
    draw.text((10, 10), text, fill="red", font=font)
    return image

def crop_image(raw_folder, cropped_folder, image):
    # takes a random input image and crops it

    # checks if the output folder exists, if not makes one
    os.makedirs(cropped_folder, exist_ok=True)

    raw_path = os.path.join(raw_folder, image)
    cropped_filename = f"cropped_{image}"  # Add "cropped_" prefix
    cropped_path = os.path.join(cropped_folder, cropped_filename)

    if os.path.exists(cropped_path):
        # print(f"{cropped_filename} already cropped and present in cropped_images, skipping")
        return

    raw_image = Image.open(raw_path)
    cropped_image, _ = crop_middle(raw_image)
    cropped_image.save(cropped_path)
    print(f"Cropped and saved: {cropped_filename}")
    return

