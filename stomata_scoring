def process_random_image(raw_images_folder, cropped_images_folder, analyzed_images_folder, csv_file):
    # Get a list of all files in the raw_images_folder
    all_files = os.listdir(raw_images_folder)

    # Filter out non-image files (e.g., only keep .jpg files)
    image_files = [f for f in all_files if f.endswith(".jpg") and "ORG" not in f]

    if not image_files:
        print("No valid images found in the raw_images_folder.")
        return

    # Select a random image from the list
    random_image = random.choice(image_files)

    # Crop the random image
    crop_image(raw_images_folder, cropped_images_folder, random_image)

    # Analyze the random image
    analyze_image(cropped_images_folder, analyzed_images_folder, csv_file, random_image)

